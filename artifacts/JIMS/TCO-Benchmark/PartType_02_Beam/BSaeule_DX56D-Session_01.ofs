mode(Post)
file.open.apply("C:\Users\Koutaiba Kassem\Downloads\BSaeule_DX56D_4Cores.erg\flcdat.asc.gz", format="OFSolv/Results", variables=Recommended, increments=All, curves=All)
view.multiView.set(views="4 Views")
showMin()
showMax()
view.multiView.setActive(views=nextView)
setVariable("Scalar:Formability", view="3D View 2")
view.multiView.setActive(views=nextView)
animate(goto=Previous)
pinIncrements(ActiveScene, view="3D View 3", action=Pin)
setOption("Pinned Increments/Show", value=On)
animate(goto=End)
setVariable("Scalar:Total Distance to Reference", view="3D View 3")
fringeScaleSetCurrent(variableType=Scalar, scale=OpenForm, view="3D View 3", rangeMode=Dynamic, rangeMin=0, rangeMax=0)
view.multiView.setActive(views=nextView)
setVariable("Scalar:No Variable", view="3D View 4")
viewTransform(rotate={"Reset","z=90"})
setOption("Snapshot/Draw Coord", value=On)
setOption("Snapshot/Draw Logo", value=On)
setOption("Snapshot/Draw Border", value=On)
takeSnapshot("3D View", filename="C:\Users\Koutaiba Kassem\Downloads\BSaeule_DX56D_01.png", format=Png, backgroundColor=white, size="2400, 1600", drawTitle=On, drawLogo=On, drawCoordSys=On, drawScale=On, drawLabel=On, drawBorder=On, borderType=Outer, borderWidth=2, borderColor=white)
file.export.apply("C:\Users\Koutaiba Kassem\Downloads\BSaeule_DX56D-Results_01.csv", format="CSV/Results", append=On, objectType=Labels, marker="*", exportCoordinates=Off, title="Front Door Results")
quit()
